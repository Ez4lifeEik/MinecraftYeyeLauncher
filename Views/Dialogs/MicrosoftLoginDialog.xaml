<Window x:Class="ArclightLauncher.Views.Dialogs.MicrosoftLoginDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Microsoft 正版登录"
        Width="520"
        Height="360"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="#F7FAF7"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#132017"/>
            <Setter Property="Background" Value="#E7F1EA"/>
            <Setter Property="BorderBrush" Value="#CADBD0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#DDF5E8"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#8BC7A8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#CFE8D9"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Width="52"
                    Height="52"
                    CornerRadius="16"
                    Background="#E4F2E6"
                    BorderBrush="#C5DCCB"
                    BorderThickness="1">
                <TextBlock Text="&#xE77B;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="24"
                           Foreground="#2E5E44"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>

            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                <TextBlock Text="Microsoft 正版账号"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="#132017"/>
                <TextBlock x:Name="StatusText"
                           Text="正在向 Microsoft 请求登录验证码..."
                           Margin="0,4,0,0"
                           FontSize="12"
                           Foreground="#647168"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="2"
                Padding="18"
                CornerRadius="20"
                Background="#FFFFFFFF"
                BorderBrush="#DDE7DF"
                BorderThickness="1">
            <StackPanel>
                <TextBlock Text="在浏览器中完成登录"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="#132017"/>
                <TextBlock x:Name="MessageText"
                           Text="验证码出现后，打开网页登录并输入验证码。启动器不会保存你的 Microsoft 密码。"
                           Margin="0,8,0,14"
                           FontSize="12"
                           LineHeight="19"
                           TextWrapping="Wrap"
                           Foreground="#647168"/>

                <TextBox x:Name="CodeText"
                         Height="46"
                         IsReadOnly="True"
                         Text="等待验证码..."
                         HorizontalContentAlignment="Center"
                         VerticalContentAlignment="Center"
                         FontSize="20"
                         FontWeight="SemiBold"
                         Foreground="#132017"
                         Background="#F1F6F2"
                         BorderBrush="#D6E4DA"
                         BorderThickness="1"/>

                <TextBlock x:Name="UriText"
                           Text="https://microsoft.com/devicelogin"
                           Margin="0,12,0,0"
                           FontSize="12"
                           TextTrimming="CharacterEllipsis"
                           Foreground="#486857"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="4">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="OpenBrowserButton"
                        Content="打开网页登录"
                        IsEnabled="False"
                        Click="OpenBrowserButton_Click"
                        Style="{StaticResource ActionButtonStyle}"/>
                <Button x:Name="CopyCodeButton"
                        Content="复制验证码"
                        IsEnabled="False"
                        Margin="10,0,0,0"
                        Click="CopyCodeButton_Click"
                        Style="{StaticResource ActionButtonStyle}"/>
            </StackPanel>

            <Button Content="关闭"
                    HorizontalAlignment="Right"
                    Click="CloseButton_Click"
                    Style="{StaticResource ActionButtonStyle}"/>
        </Grid>
    </Grid>
</Window>
