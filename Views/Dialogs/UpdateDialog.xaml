<Window x:Class="ArclightLauncher.Views.Dialogs.UpdateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        Title="ArclightLauncher 更新"
        Width="520" Height="420"
        MinWidth="480" MinHeight="360"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource RegionBrush}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <!-- Invert: true→Collapsed, false→Visible -->
        <Style x:Key="HideWhenTrue" TargetType="FrameworkElement">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsDownloading}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ShowWhenTrue" TargetType="FrameworkElement">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsDownloading}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="28,24,28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="4"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0"
                   Text="ArclightLauncher 更新"
                   FontSize="18" FontWeight="SemiBold"
                   Foreground="{DynamicResource PrimaryTextBrush}"/>

        <!-- 版本对比 + 大小 -->
        <StackPanel Grid.Row="2">
            <StackPanel Orientation="Horizontal">
                <Border Padding="8,3" CornerRadius="8"
                        Background="{DynamicResource SecondaryRegionBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1">
                    <TextBlock Text="{Binding CurrentVersion, StringFormat='当前 v{0}'}"
                               FontSize="12"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                </Border>
                <TextBlock Text="  →  "
                           FontSize="14" FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource PrimaryBrush}"/>
                <Border Padding="8,3" CornerRadius="8"
                        Background="{DynamicResource PrimaryBrush}"
                        BorderThickness="0">
                    <TextBlock Text="{Binding NewVersion, StringFormat='最新 v{0}'}"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="White"/>
                </Border>
            </StackPanel>
            <TextBlock Text="{Binding DownloadSizeText, StringFormat='安装包大小：{0}'}"
                       Margin="0,6,0,0"
                       FontSize="12"
                       Foreground="{DynamicResource SecondaryTextBrush}"
                       Visibility="{Binding DownloadSizeText, Converter={StaticResource BoolToVis}}"/>
        </StackPanel>

        <!-- 状态文字（下载前为版本信息，下载中为进度文字） -->
        <TextBlock Grid.Row="4"
                   Text="{Binding StatusText}"
                   FontSize="12"
                   Foreground="{DynamicResource SecondaryTextBrush}"
                   TextTrimming="CharacterEllipsis"/>

        <!-- 更新日志 -->
        <ScrollViewer Grid.Row="6"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Background="{DynamicResource SecondaryRegionBrush}"
                      Padding="12,10"
                      Visibility="{Binding HasReleaseNotes, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{Binding ReleaseNotes}"
                       TextWrapping="Wrap"
                       FontSize="12"
                       Foreground="{DynamicResource SecondaryTextBrush}"/>
        </ScrollViewer>

        <!-- 下载进度条 -->
        <Grid Grid.Row="8"
              Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="4"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <ProgressBar Grid.Row="0"
                         Value="{Binding Progress}" Minimum="0" Maximum="100"
                         Height="6"/>
            <TextBlock Grid.Row="2"
                       Text="{Binding Progress, StringFormat={}{0:F0}%}"
                       FontSize="11"
                       HorizontalAlignment="Right"
                       Foreground="{DynamicResource SecondaryTextBrush}"/>
        </Grid>

        <!-- 按钮行 -->
        <StackPanel Grid.Row="12" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="跳过"
                    Command="{Binding SkipCommand}"
                    Style="{StaticResource HideWhenTrue}"
                    Padding="16,7" Margin="0,0,8,0"
                    Foreground="{DynamicResource SecondaryTextBrush}"
                    Background="Transparent" BorderBrush="Transparent"/>
            <Button Content="取消下载"
                    Command="{Binding CancelDownloadCommand}"
                    Style="{StaticResource ShowWhenTrue}"
                    Padding="16,7" Margin="0,0,8,0"
                    Foreground="{DynamicResource SecondaryTextBrush}"
                    Background="Transparent" BorderBrush="Transparent"/>
            <Button Content="立即更新"
                    Command="{Binding UpdateNowCommand}"
                    Style="{StaticResource HideWhenTrue}"
                    Padding="20,7"
                    Foreground="White"
                    Background="#7DDB65"
                    BorderThickness="0">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="14"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>
