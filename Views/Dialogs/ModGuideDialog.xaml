<Window x:Class="ArclightLauncher.Views.Dialogs.ModGuideDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="服务器 Mod 使用说明"
        Width="860"
        Height="680"
        MinWidth="720"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="#F7FAF7"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#132017"/>
            <Setter Property="Background" Value="#E7F1EA"/>
            <Setter Property="BorderBrush" Value="#CADBD0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#DDF5E8"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#8BC7A8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#CFE8D9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Width="52"
                    Height="52"
                    CornerRadius="14"
                    Background="#E4F2E6"
                    BorderBrush="#C5DCCB"
                    BorderThickness="1">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Rectangle Fill="#77CF5A" RadiusX="3" RadiusY="3"/>
                    <Rectangle Grid.Row="1" Fill="#8A6138" RadiusX="3" RadiusY="3"/>
                    <Rectangle Grid.Row="1" Width="10" HorizontalAlignment="Left" Fill="#A67843"/>
                    <Rectangle Grid.Row="0" Width="12" HorizontalAlignment="Right" Fill="#B7ED80"/>
                </Grid>
            </Border>

            <StackPanel Grid.Column="2"
                        VerticalAlignment="Center">
                <TextBlock Text="烨夜服 Mod 使用说明"
                           FontSize="26"
                           FontWeight="SemiBold"
                           Foreground="#132017"/>
                <TextBlock Text="{Binding ModsFolderText}"
                           Margin="0,5,0,0"
                           FontSize="12"
                           Foreground="#647168"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="2"
                Background="#FFFFFFFF"
                BorderBrush="#DDE7DF"
                BorderThickness="1"
                CornerRadius="18"
                Padding="0">
            <Grid>
                <TextBox x:Name="GuideText"
                         Margin="0"
                         Padding="22"
                         IsReadOnly="True"
                         BorderThickness="0"
                         Background="Transparent"
                         Foreground="#1C2A20"
                         FontSize="13"
                         FontFamily="Microsoft YaHei UI"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Disabled"/>
            </Grid>
        </Border>

        <Grid Grid.Row="4">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Left">
                <Button Content="打开 mods 文件夹"
                        Click="OpenModsFolderButton_Click"
                        Style="{StaticResource ActionButtonStyle}"/>
                <Button Content="刷新说明"
                        Margin="10,0,0,0"
                        Click="ReloadGuideButton_Click"
                        Style="{StaticResource ActionButtonStyle}"/>
            </StackPanel>

            <Button Content="关闭"
                    HorizontalAlignment="Right"
                    Click="CloseButton_Click"
                    Style="{StaticResource ActionButtonStyle}"/>
        </Grid>
    </Grid>
</Window>
