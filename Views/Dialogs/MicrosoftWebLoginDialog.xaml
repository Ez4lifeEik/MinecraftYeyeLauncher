<Window x:Class="ArclightLauncher.Views.Dialogs.MicrosoftWebLoginDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Microsoft 正版登录"
        Width="920"
        Height="700"
        MinWidth="760"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="#F7FAF7"
        FontFamily="Segoe UI">

    <Window.Resources>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Foreground" Value="#132017"/>
            <Setter Property="Background" Value="#E7F1EA"/>
            <Setter Property="BorderBrush" Value="#CADBD0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#DDF5E8"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="#8BC7A8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="#CFE8D9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Width="52"
                    Height="52"
                    CornerRadius="16"
                    Background="#E4F2E6"
                    BorderBrush="#C5DCCB"
                    BorderThickness="1">
                <TextBlock Text="&#xE77B;"
                           FontFamily="Segoe MDL2 Assets"
                           FontSize="24"
                           Foreground="#2E5E44"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>

            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                <TextBlock Text="Microsoft 正版登录"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Foreground="#132017"/>
                <TextBlock x:Name="StatusText"
                           Text="请在 Microsoft 官方页面完成登录"
                           Margin="0,4,0,0"
                           FontSize="12"
                           Foreground="#647168"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="2"
                CornerRadius="20"
                Background="#FFFFFFFF"
                BorderBrush="#DDE7DF"
                BorderThickness="1"
                ClipToBounds="True">
            <wv2:WebView2 x:Name="LoginBrowser"/>
        </Border>

        <Grid Grid.Row="4">
            <TextBlock Text="这是 Microsoft 官方登录页。启动器只接收登录完成后的令牌，不读取、不保存你的密码。"
                       VerticalAlignment="Center"
                       FontSize="12"
                       Foreground="#647168"/>

            <Button Content="取消"
                    HorizontalAlignment="Right"
                    Click="CancelButton_Click"
                    Style="{StaticResource ActionButtonStyle}"/>
        </Grid>
    </Grid>
</Window>
