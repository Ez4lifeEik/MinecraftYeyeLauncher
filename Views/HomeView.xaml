<UserControl x:Class="ArclightLauncher.Views.HomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:hc="https://handyorg.github.io/handycontrol">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- 分割按钮内部透明区域样式（主/副两侧共用） -->
        <Style x:Key="SplitPartStyle" TargetType="Button">
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Foreground"       Value="White"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent"
                                CornerRadius="{TemplateBinding Tag}">
                            <ContentPresenter HorizontalAlignment="Center"
                                             VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#22FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#33000000"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Popup 内列表项样式 -->
        <Style x:Key="PopupItemStyle" TargetType="Button">
            <Setter Property="Background"              Value="Transparent"/>
            <Setter Property="BorderThickness"         Value="0"/>
            <Setter Property="HorizontalAlignment"     Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding"                 Value="14,9"/>
            <Setter Property="FontSize"                Value="13"/>
            <Setter Property="Cursor"                  Value="Hand"/>
            <Setter Property="FocusVisualStyle"        Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="Transparent" CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                             VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource SecondaryRegionBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══ 左栏 ════════════════════════════════════════════════════════ -->
        <Border Grid.Column="0" Background="{DynamicResource SecondaryRegionBrush}">
            <Grid>
                <!--
                    DockPanel：
                      Top    → 认证 + 头像 + 用户名
                      Bottom → 启动按钮（最底）
                      Bottom → 进度条 / 状态（按钮正上方，仅启动时显示）
                      中间   → 自动空白留白
                -->
                <DockPanel Margin="24" LastChildFill="False">

                    <!-- ── 顶部：认证徽章 + 头像 + 用户名 ── -->
                    <StackPanel DockPanel.Dock="Top">

                        <!-- 认证类型 -->
                        <StackPanel Orientation="Horizontal">
                            <Border Background="{DynamicResource PrimaryBrush}"
                                    CornerRadius="3" Padding="10,4" Margin="0,0,6,0">
                                <TextBlock Text="离线" Foreground="White" FontSize="12"/>
                            </Border>
                            <Border Background="{DynamicResource BorderBrush}"
                                    CornerRadius="3" Padding="10,4">
                                <TextBlock Text="正版 (v0.3)"
                                           Foreground="{DynamicResource ThirdlyTextBrush}"
                                           FontSize="12"/>
                            </Border>
                        </StackPanel>

                        <!-- 头像 -->
                        <Border Width="80" Height="80"
                                Background="{DynamicResource PrimaryBrush}"
                                CornerRadius="10"
                                HorizontalAlignment="Center"
                                Margin="0,24,0,0">
                            <TextBlock Text="{Binding UsernameInitial}"
                                       Foreground="White" FontSize="38" FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <!-- 用户名 -->
                        <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                                 hc:InfoElement.Placeholder="输入游戏中显示的名称"
                                 MaxLength="16"
                                 TextAlignment="Center"
                                 HorizontalAlignment="Stretch"
                                 Margin="0,16,0,0"/>

                    </StackPanel>

                    <!-- ── 底部：启动分割按钮 ── -->
                    <Border x:Name="SplitBorder"
                            DockPanel.Dock="Bottom"
                            Background="{DynamicResource PrimaryBrush}"
                            CornerRadius="6"
                            Height="60"
                            ClipToBounds="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="1"/>
                                <ColumnDefinition Width="48"/>
                            </Grid.ColumnDefinitions>

                            <!-- 主区：点击=启动 -->
                            <Button Grid.Column="0"
                                    Command="{Binding LaunchCommand}"
                                    Style="{StaticResource SplitPartStyle}"
                                    Tag="6,0,0,6">
                                <StackPanel>
                                    <TextBlock Text="启动游戏"
                                               Foreground="White"
                                               FontSize="15" FontWeight="SemiBold"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding LaunchButtonSubtitle}"
                                               Foreground="White" Opacity="0.75"
                                               FontSize="11"
                                               HorizontalAlignment="Center"
                                               Margin="0,3,0,0"/>
                                </StackPanel>
                            </Button>

                            <!-- 分隔线 -->
                            <Rectangle Grid.Column="1" Fill="White" Opacity="0.25"/>

                            <!-- 副区：点击=展开模式 Popup -->
                            <Button x:Name="DropdownBtn"
                                    Grid.Column="2"
                                    Style="{StaticResource SplitPartStyle}"
                                    Tag="0,6,6,0"
                                    Click="DropdownBtn_Click">
                                <TextBlock Text="▾" Foreground="White"
                                           FontSize="15" VerticalAlignment="Center"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- ── 底部：进度条 + 状态（仅启动时显示） ── -->
                    <StackPanel DockPanel.Dock="Bottom"
                                Margin="0,0,0,14"
                                Visibility="{Binding IsLaunching, Converter={StaticResource BoolToVis}}">
                        <ProgressBar Value="{Binding Progress}" Maximum="100"
                                     Height="4" Margin="0,0,0,6"/>
                        <TextBlock Text="{Binding StatusText}"
                                   FontSize="11" TextWrapping="Wrap"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                    </StackPanel>

                </DockPanel>

                <!-- ── 模式选择 Popup（浮于左栏之上） ── -->
                <Popup x:Name="ModePopup"
                       PlacementTarget="{Binding ElementName=SplitBorder}"
                       Placement="Top"
                       VerticalOffset="-4"
                       StaysOpen="False"
                       AllowsTransparency="True">
                    <Border Background="{DynamicResource RegionBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="4,6"
                            MinWidth="{Binding ActualWidth, ElementName=SplitBorder}"
                            Effect="{StaticResource EffectShadow2}">
                        <StackPanel>

                            <!-- 朝夕服 -->
                            <Button Command="{Binding SelectOfficialServerCommand}"
                                    Style="{StaticResource PopupItemStyle}"
                                    Click="ModeItem_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="●" Width="18" FontSize="9"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource PrimaryBrush}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsOfficialServerMode}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Width="18" Text=""
                                               Visibility="{Binding IsOfficialServerMode,
                                                   Converter={StaticResource BoolToVis}}">
                                        <!-- 占位，使无选中时文字对齐 -->
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsOfficialServerMode}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="进入朝夕服">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsOfficialServerMode}" Value="True">
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Button>

                            <!-- 单机 -->
                            <Button Command="{Binding SelectSingleplayerCommand}"
                                    Style="{StaticResource PopupItemStyle}"
                                    Click="ModeItem_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="●" Width="18" FontSize="9"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource PrimaryBrush}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSingleplayerMode}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Width="18">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSingleplayerMode}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="单机游戏">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSingleplayerMode}" Value="True">
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Button>

                            <Separator Margin="4,4"/>

                            <!-- 其他服务器 -->
                            <Button Command="{Binding SelectCustomServerCommand}"
                                    Style="{StaticResource PopupItemStyle}"
                                    Click="ModeItem_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="●" Width="18" FontSize="9"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource PrimaryBrush}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCustomServerMode}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Width="18">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCustomServerMode}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="连接其他服务器……">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsCustomServerMode}" Value="True">
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Button>

                        </StackPanel>
                    </Border>
                </Popup>

            </Grid>
        </Border>

        <!-- ══ 右栏：服务器信息 + 公告 ═══════════════════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 服务器信息卡 -->
            <Border Grid.Row="0"
                    Margin="20,20,20,12"
                    Background="{DynamicResource SecondaryRegionBrush}"
                    CornerRadius="8" Padding="20,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="朝夕服" FontSize="18" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding ServerAddress}"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontSize="13"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <TextBlock Text="整合包版本" FontSize="11"
                                   Foreground="{DynamicResource ThirdlyTextBrush}"
                                   HorizontalAlignment="Right"/>
                        <TextBlock Text="{Binding PackVersion}"
                                   FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryBrush}"
                                   HorizontalAlignment="Right"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 公告 -->
            <ScrollViewer Grid.Row="1" Margin="20,0,20,20"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="公告"
                               FontSize="14" FontWeight="SemiBold"
                               Margin="0,0,0,8"
                               Visibility="{Binding Announcement,
                                   Converter={StaticResource String2VisibilityConverter}}"/>
                    <TextBlock Text="{Binding Announcement}"
                               TextWrapping="Wrap" FontSize="13" LineHeight="22"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <TextBlock Text="暂无公告" FontSize="13"
                               Foreground="{DynamicResource ThirdlyTextBrush}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Announcement}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </ScrollViewer>
        </Grid>

    </Grid>
</UserControl>
