<Window x:Class="ArclightLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="迷你世界 启动器"
        Height="820"
        Width="1280"
        MinHeight="760"
        MinWidth="1040"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        WindowState="Maximized"
        ResizeMode="CanResize"
        Background="#101711"
        FontFamily="Segoe UI"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Ideal">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Styles/LauncherGlassTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <!-- The current views stay in the original TabControl so existing navigation and ViewModels are preserved. -->
        <TabControl x:Name="MainTabs"
                    SelectedIndex="{Binding SelectedTab}"
                    Background="Transparent"
                    BorderThickness="0"
                    Padding="0">
            <TabControl.Template>
                <ControlTemplate TargetType="TabControl">
                    <ContentPresenter ContentSource="SelectedContent"/>
                </ControlTemplate>
            </TabControl.Template>

            <TabItem Content="{Binding HomeVm}"/>
            <TabItem Content="{Binding SettingsVm}"/>
            <TabItem Content="{Binding AboutVm}"/>
        </TabControl>

        <Grid Height="76"
              VerticalAlignment="Top"
              Margin="26,14,26,0"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center">
                <Border Width="38"
                        Height="38"
                        CornerRadius="10"
                        BorderBrush="{StaticResource GlassStroke}"
                        BorderThickness="1"
                        Background="#36FFFFFF"
                        Effect="{StaticResource SoftShadow}">
                    <Grid Margin="6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Rectangle Fill="#79D85C" RadiusX="2" RadiusY="2"/>
                        <Rectangle Grid.Row="1" Fill="#8B623A" RadiusX="2" RadiusY="2"/>
                        <Rectangle Grid.Row="1" Width="8" HorizontalAlignment="Left" Fill="#A87844"/>
                        <Rectangle Grid.Row="0" Width="9" HorizontalAlignment="Right" Fill="#B2EF7E"/>
                    </Grid>
                </Border>

                <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="迷你世界 启动器"
                               FontSize="17"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimary}"/>
                    <TextBlock Text="创造你的迷你世界"
                               Margin="0,2,0,0"
                               FontSize="11"
                               Foreground="{StaticResource TextMuted}"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                <Button Content="&#xE921;"
                        ToolTip="最小化"
                        Style="{StaticResource ChromeButtonStyle}"
                        Click="MinimizeButton_Click"/>
                <Button Content="&#xE922;"
                        ToolTip="最大化 / 还原"
                        Style="{StaticResource ChromeButtonStyle}"
                        Click="MaximizeButton_Click"/>
                <Button Content="&#xE8BB;"
                        ToolTip="关闭"
                        Style="{StaticResource ChromeButtonStyle}"
                        Click="CloseButton_Click"/>
            </StackPanel>
        </Grid>

        <StackPanel HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Margin="28,0,0,28">
            <Button Content="&#xE774;"
                    ToolTip="语言"
                    Style="{StaticResource RoundGlassButtonStyle}"
                    Click="LanguageButton_Click"/>
            <Button Content="&#xE713;"
                    ToolTip="设置"
                    Style="{StaticResource RoundGlassButtonStyle}"
                    Click="SettingsButton_Click"/>
            <Button Content="&#xE71B;"
                    ToolTip="官网"
                    Style="{StaticResource RoundGlassButtonStyle}"
                    Click="WebsiteButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
