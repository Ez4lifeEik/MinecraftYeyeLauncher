<Window x:Class="ArclightLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ArclightLauncher" Height="640" Width="940"
        MinHeight="560" MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource RegionBrush}">

    <Window.Resources>
        <Style x:Key="TabItemStyle" TargetType="TabItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Grid>
                            <Border x:Name="Bd" Padding="20,0" Background="Transparent"
                                    Height="44" VerticalAlignment="Stretch">
                                <TextBlock x:Name="Txt"
                                           Text="{TemplateBinding Header}"
                                           Foreground="White" Opacity="0.65"
                                           FontSize="14"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <Border x:Name="Indicator" Height="3"
                                    Background="White"
                                    VerticalAlignment="Bottom" Opacity="0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Txt"       Property="Opacity"    Value="1"/>
                                <Setter TargetName="Txt"       Property="FontWeight" Value="SemiBold"/>
                                <Setter TargetName="Indicator" Property="Opacity"    Value="1"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                    <Condition Property="IsSelected"  Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Txt" Property="Opacity" Value="0.9"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <TabControl SelectedIndex="{Binding SelectedTab}" BorderThickness="0" Padding="0">
        <TabControl.Template>
            <ControlTemplate TargetType="TabControl">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="44"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Background="{DynamicResource PrimaryBrush}">
                        <TabPanel IsItemsHost="True"
                                  VerticalAlignment="Stretch"
                                  Background="Transparent"
                                  HorizontalAlignment="Left"
                                  Margin="8,0"/>
                    </Border>
                    <ContentPresenter Grid.Row="1" ContentSource="SelectedContent"/>
                </Grid>
            </ControlTemplate>
        </TabControl.Template>

        <TabItem Header="启动" Style="{StaticResource TabItemStyle}" Content="{Binding HomeVm}"/>
        <TabItem Header="设置" Style="{StaticResource TabItemStyle}" Content="{Binding SettingsVm}"/>
        <TabItem Header="关于" Style="{StaticResource TabItemStyle}" Content="{Binding AboutVm}"/>
    </TabControl>
</Window>
